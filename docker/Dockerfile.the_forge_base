# =============================================================================
# Stage 1: cargo-chef planner - analyze dependencies
# =============================================================================
FROM rust:bookworm AS planner

RUN cargo install cargo-chef --locked
WORKDIR /usr/src/app

# Copy only Cargo files for dependency analysis
COPY Cargo.toml Cargo.lock ./
COPY core/Cargo.toml core/Cargo.toml
COPY bot_foundry/Cargo.toml bot_foundry/Cargo.toml
COPY the_forge/Cargo.toml the_forge/Cargo.toml
COPY agent_foundry/Cargo.toml agent_foundry/Cargo.toml

# Create dummy source files
RUN mkdir -p core/src bot_foundry/src the_forge/src agent_foundry/src && \
    echo "fn main() {}" > bot_foundry/src/main.rs && \
    echo "fn main() {}" > the_forge/src/main.rs && \
    echo "fn main() {}" > agent_foundry/src/main.rs && \
    echo "pub fn dummy() {}" > core/src/lib.rs

# Generate dependency recipe
RUN cargo chef prepare --recipe-path recipe.json

# =============================================================================
# Stage 2: Build Rust dependencies (CACHED!)
# =============================================================================
FROM rust:bookworm AS cacher

RUN cargo install cargo-chef --locked

RUN apt-get update && apt-get install -y \
    pkg-config \
    libssl3 \
    libssl-dev \
    libsqlite3-dev \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /usr/src/app
COPY --from=planner /usr/src/app/recipe.json recipe.json

# Build dependencies - this layer is heavily cached!
RUN --mount=type=cache,target=/usr/local/cargo/registry \
    --mount=type=cache,target=/usr/local/cargo/git \
    cargo chef cook --release --recipe-path recipe.json -p the_forge

# =============================================================================
# Stage 3: Build the_forge application
# =============================================================================
FROM rust:bookworm AS builder

RUN apt-get update && apt-get install -y \
    pkg-config \
    libssl3 \
    libsqlite3-dev \
    ffmpeg \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /usr/src/app

# Copy cached dependencies from cacher stage
COPY --from=cacher /usr/src/app/target target

# Copy source code
COPY Cargo.toml Cargo.lock ./
COPY core core/
COPY the_forge the_forge/
COPY bot_foundry bot_foundry/
COPY agent_foundry agent_foundry/

# Build the_forge with cache mounts for incremental compilation
RUN --mount=type=cache,target=/usr/local/cargo/registry \
    --mount=type=cache,target=/usr/local/cargo/git \
    --mount=type=cache,target=/usr/src/app/target,sharing=locked \
    cargo build -p the_forge --release -j 4 && \
    cp target/release/the_forge /tmp/the_forge

# =============================================================================
# Stage 4: Runtime image
# =============================================================================
FROM debian:bookworm-slim AS the_forge_base

RUN apt-get update && apt-get install -y \
    ca-certificates \
    libssl3 \
    libsqlite3-0 \
    ffmpeg \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app

# Copy binary from builder
COPY --from=builder /tmp/the_forge .

RUN chown 1001:1000 /app/the_forge && \
    chmod +x /app/the_forge

RUN mkdir -p tmp && \
    chown 1001:1000 tmp && \
    chmod 700 tmp && \
    chown -R 1001:1000 /app && \
    chmod 755 /app

COPY docker/the_forge_entrypoint.sh ./entrypoint.sh
RUN chmod +x entrypoint.sh

USER 1001:1000

ENTRYPOINT ["./entrypoint.sh"]
