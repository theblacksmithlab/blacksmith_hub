# Rust build artifacts (HUGE - ~5GB!)
target/
**/*.rs.bk
**/*.pdb

# Git
.git/
.gitignore

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

# Environment files (secrets!)
.env
.env.local
.env.*.local

# Docker (don't copy docker files into build)
docker-compose.yml
docker-compose.*.yml
Dockerfile*
.dockerignore

# Documentation
docs/
*.md
!CLAUDE.md

# Logs
*.log
logs/

# OS files
.DS_Store
Thumbs.db

# Node (if any)
node_modules/
npm-debug.log*

# Python
__pycache__/
*.py[cod]
.Python
venv/
env/

# Temporary files
tmp/
temp/
*.tmp
*.cache

# Backups
*.backup*
*.bak

# Note: DO NOT exclude *.sh - we need entrypoint.sh!
# Note: DO NOT exclude *.so - not relevant (whisper builds inside image)
